  let exp = "https://github.com/example/repo/tree/main/"
  assert ($res == $exp) $"When a repository with an SSH remote URL is provided, then the result should be a URL with https and without port and username. Result: ($res), Expected: ($exp)"

  let remote = {name: "origin", url: ("ssh://user:password@cloud.gitea.com:1234/example/repo" | transform-remote)}
  let res = $ctx | join-url $config $remote "main"
  let exp = "https://cloud.gitea.com/example/repo/src/branch/main/"
  assert ($res == $exp) $"When a repository with an SSH user and password is provided, then the result should be a URL without username and password. Result: ($res), Expected: ($exp)"

  log info "All tests passed"
}

# Builds the URL of the current repository and path in the source control hub
def main [
  path: path = ""
  # File or directory path, defaults to the root of the repository
  --open (-o)
  # Open URL in browser
  --copy (-c)
  # Copy URL into the clipboard
  --remote (-r): string
  # Specific remote name, defaults to the first remote
  --verbose (-v)
  # Verbose log output
  --version (-V)
  # Print huburl version
  --pr (-P)
  # Create PR
  --remote-pr (-R): string
  # Name of remote
  --branch-pr (-B): string
  # Name of target branch for PR, defaults to main
  --test
  # Run tests (just for development)
]: nothing -> string {
  if $test {
    test-join-url
    return
  }
  if $version {
    return $VERSION
  }
  if $verbose {
    $env.NU_LOG_LEVEL = "debug"
  }
  let path = $path | parse --regex '^(?<path>[^:]+)(?::(?<linenr>[0-9]+))?$' | if ($in | is-not-empty) {first | update path ($in.path | path expand)} else {{path: (pwd | path expand), linenr: null}}
  let ctx = $path.path | find-root
  cd $ctx.directory
  log debug $"repository root directory: ($ctx.directory)"
  let branch = $ctx | get-current-branch
  log debug $"current branch: ($branch)"
  let remote = $ctx | get-remote $remote
  log debug $"current remote: ($remote)"
  let path = $path | update path ($in.path | path relative-to $ctx.directory)
  log debug $"relative path: ($path)"
  let config = load-config
  let remote_pr = if ($remote_pr | is-empty) { "upstream" } else { $remote_pr }
  log debug $"remote pr: ($remote_pr)"
  let branch_pr = if ($branch_pr | is-empty) { "main" } else { $branch_pr }
  log debug $"branch pr: ($branch_pr)"
  let upstream_remote = try {
    $ctx | get-remote $remote_pr
  } catch {
    $ctx | get-remote $remote.name
  }
  log debug $"current upstream: ($upstream_remote)"
  let url = if $pr {
    $ctx | join-url $config $remote $branch --upstream-remote $upstream_remote --upstream-branch $branch_pr
  } else {
    $ctx | join-url $config $remote $branch --path $path
  }
  log debug $"url: ($url)"
  if $open {
    let cmd = if ((sys host).long_os_version | str starts-with "Linux") {
      "xdg-open"
    } else {
      "open"
    }
    run-external $cmd $url
  }
  if $copy { $url | clip copy }
  $url
}